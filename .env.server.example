# 0DTE Daily — Server Environment Variables
# Copy to /opt/zeroday/.env on the server and fill in real values

# Schwab API (get from developer.schwab.com)
SCHWAB_APP_KEY=your_client_id_here
SCHWAB_APP_SECRET=your_client_secret_here
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182

# File paths (relative to /opt/zeroday/)
TOKEN_FILE=schwab_token.json
MARKET_DATA_DIR=market_data
DAILY_BRIEF_DIR=daily_briefs

# OptiPub (get from OptiPub Settings > API)
OPTIPUB_API_KEY=your_optipub_api_key_here
OPTIPUB_API_BASE=https://optionpit.app.optipub.com/api/3.2
ZERO_DAY_PUBLICATION_ID=103

# Notifications — use existing Slack webhook
NOTIFY_METHOD=slack
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Auth — password to access the form and preview pages
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(16))"
ZERODAY_PASSWORD=your_strong_password_here

# Server
SERVER_BASE_URL=https://optionpit-api.duckdns.org
